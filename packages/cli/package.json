{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "@yantrix/cli",
	"version": "0.1.0",
	"description": "CLI for Yantrix components",
	"keywords": [
		"FSM",
		"Miely Machine"
	],
	"homepage": "https://github.com/tfcp68/yantrix",
	"bugs": {
		"url": "https://github.com/tfcp68/yantrix/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/tfcp68/yantrix.git",
		"directory": "packages/cli"
	},
	"license": "MIT",
	"contributors": [
		"Alexander Uskov <neolord.tmb@gmail.com>",
		"Etheresk <etheresked@gmail.com>",
		"Denis Perevertov <regicuinte@gmail.com>",
		"Nikita Beliaew <nekitech-x@mail.ru>",
		"Sin <shulgin.grigoriy@yandex.ru>",
		"Alexey Geraim <oblivion25565@gmail.com>",
		"Саша <https://github.com/22sasha>"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"yantrix": "dist/bin/yantrix.js"
	},
	"directories": {
		"lib": "src",
		"bin": "bin"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "rimraf dist && tsc",
		"format": "prettier --write . && cross-env TIMING=1 eslint --fix src",
		"lint": "prettier --check . && cross-env TIMING=1 eslint src"
	},
	"dependencies": {
		"@yantrix/automata": "workspace:^",
		"@yantrix/codegen": "workspace:^",
		"@yantrix/mermaid-parser": "workspace:^",
		"commander": "^12.1.0",
		"fs-extra": "^11.2.0",
		"picocolors": "^1.0.1"
	},
	"devDependencies": {
		"@types/fs-extra": "^11.0.4",
		"tsx": "^4.11.0"
	},
	"engines": {
		"node": ">=18"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	}
}
