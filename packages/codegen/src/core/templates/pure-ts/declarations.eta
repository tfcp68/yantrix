export type TActions<%~ it.className %> = keyof typeof actionsMap;

type TFunctionRegistry = {
  register(nameOrDict: string | Record<string, (...args: unknown[]) => unknown>, fn?: (...args: unknown[]) => unknown): void;
  get(name: string): ((...args: unknown[]) => unknown) | undefined;
  call(name: string, ...args: unknown[]): unknown;
  has(name: string): boolean;
};

type TEventAdapter = {
  addEventEmitter(stateId: number, fn: (ctx: { state: number; context: TAutomataContext }) => unknown): void;
  addEventListener(eventId: number, fn: (ev: { event: number; meta: TAutomataPayload }) => unknown): void;
  handleEvent(ev: { event: number; meta: TAutomataPayload }): Array<{ action: number; payload: TAutomataPayload }>;
  handleTransition(ctx: { state: number; context: TAutomataContext }): unknown[];
};

export type T<%~ it.className %>Instance = {
