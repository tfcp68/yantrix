  readonly lastAction: TActionId | null;
  readonly currentCycle: number;
  readonly eventAdapter: TEventAdapter;
  dispatch(ap: { action: TActionId; payload: TAutomataPayload }): { state: TStateId; context: TAutomataContext };
  getContext(): { state: TStateId; context: TAutomataContext };
  pause(): T<%~ it.className %>Instance;
  resume(): T<%~ it.className %>Instance;
  enable(): T<%~ it.className %>Instance;
  disable(clearQueue?: boolean): T<%~ it.className %>Instance;
  destroy(): void;
};

