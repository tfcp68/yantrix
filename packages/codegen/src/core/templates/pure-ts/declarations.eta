export type TStateId = number;
export type TActionId = number;
export type TAutomataContext = Record<string, unknown>;
export type TAutomataPayload = Record<string, unknown> | null;
export type TReducerPayload = Exclude<TAutomataPayload, null>;

export declare const statesDictionary: Record<string, TStateId>;
export declare const actionsDictionary: Record<string, TActionId>;
export declare const eventDictionary: Record<string, number>;
export declare const actionsMap: Record<string, string>;
