<% if (it.source.kind === 'defaultProperty') { %>
<%~ include('../../../shared/expressions/context/defaultPropertyContext', {
  path: it.source.path,
  identifier: it.source.identifier,
  expression: it.source.fallbackExpression,
}) %>
<% } else { %>
(function(){
  return <%~ it.source.expressionValueRight %>
}())
<% } %>

