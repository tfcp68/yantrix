eventAdapter.addEventListener(
  eventDictionary["<%~ it.listener.eventIdentifier %>"],
  <% if (it.listener.payloadEntries.length > 0) { %>({ event: _event, meta })<% } else { %>()<% } %> => {
    return {
      action: actionsDictionary["<%~ it.listener.actionName %>"],
      payload: {
        <%~ it.listener.payloadEntries.map((entry) => include('../payload', { entry })).join(',\n        ') %>
      },
    };
  },
);
