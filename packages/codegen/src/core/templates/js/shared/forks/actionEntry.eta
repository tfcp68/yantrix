<% const transitions = it.predicate?.transitions ?? []; %>
<%~ it.actionId %>: (prevContext<% if (it.hasTypes) { %>: TAutomataContext<% } %>, _payload<% if (it.hasTypes) { %>: TReducerPayload<% } %>, functionDictionary<% if (it.hasTypes) { %>: FunctionDictionary<% } %>) => {
<% for (let transitionIndex = 0; transitionIndex < transitions.length; transitionIndex++) { %>
  <%~ include('transition', {
	transition: transitions[transitionIndex],
	transitionIndex,
  }) %>
<% } %>
  return null;
},


