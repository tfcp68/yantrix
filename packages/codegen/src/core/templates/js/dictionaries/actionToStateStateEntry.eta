<%~ it.stateId %>: {
<%
const actionEntries = Object.entries(it.actions ?? {});
for (let index = 0; index < actionEntries.length; index++) {
  const [actionId, entry] = actionEntries[index];
%>
  <%~ include('actionToStateEntry', { stateId: it.stateId, actionId, entry }) %><% if (index < actionEntries.length - 1) { %>,<% } %>
<% } %>
}
