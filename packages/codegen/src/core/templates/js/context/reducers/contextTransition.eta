<% if (it.transition.kind === 'prevContext') { %>
prevContext
<% } else { %>
{
<%~ it.transition.items.map((item) => {
  if (item.kind === 'withReducer') {
    return include('contextItemWithReducer', { boundValues: item.boundValues });
  }

  return include('contextItemNoReducer', {
    identifier: item.identifier,
    defaultExpressionValueRight: item.defaultExpressionValueRight,
  });
}).join(',\n\t') %>
}
<% } %>

