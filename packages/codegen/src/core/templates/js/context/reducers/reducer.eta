const reducer = {
<% for (const st of it.diagram.states) { %>
  <% const stateValue = it.stateDictionary.getStateValues({ keys: [st.id] })[0]; %>
  <%~ stateValue %>: (prevContext, payload, functionDictionary, automata) => {
    return <%~ include('contextTransition', {
      diagram: it.diagram,
      expressions: it.expressions,
      stateDictionary: it.stateDictionary,
      value: stateValue,
      contextSerializer: it.contextSerializer,
    }) %>
  },
<% } %>
}

