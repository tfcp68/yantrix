<% if (it.defaultContextModel.startStateValue != null && it.defaultContextModel.transition) { %>
const getDefaultContext = (prevContext, payload) => {
  const ctx = <%~ include('../reducers/contextTransition', {
    transition: it.defaultContextModel.transition,
  }) %>;
  return Object.assign({}, prevContext, ctx);
}
<% } else { %>
const getDefaultContext = (prevContext, payload) => prevContext
<% } %>


