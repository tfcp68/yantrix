<% if (it.defaultContext.startStateValue != null && it.defaultContext.transition) { %>
const getDefaultContext = (prevContext, payload) => {
  const ctx = <%~ include('../../../shared/context/reducers/contextTransition', {
    transition: it.defaultContext.transition,
  }) %>;
  return Object.assign({}, prevContext, ctx);
}
<% } else { %>
const getDefaultContext = (prevContext, payload) => prevContext
<% } %>


