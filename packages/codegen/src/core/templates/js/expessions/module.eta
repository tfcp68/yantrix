<%
const model = it.model;
%>
<% if (model == null) { %>
null
<% } else if (model.kind === 'raw') { %>
<%~ model.value %>
<% } else if (model.kind === 'functionCall' && model.isInternal === true) { %>
<%~ include('internalFunctionCall', { model }) %>
<% } else if (model.kind === 'functionCall') { %>
<%~ include('functionCall', { model }) %>
<% } else { %>
null
<% } %>

