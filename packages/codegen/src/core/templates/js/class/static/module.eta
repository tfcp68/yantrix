  static getState = (state) => statesDictionary[state];
  static hasState = (instance, state) => instance.state === <%~ it.className %>.getState(state);
  static getAction = (action) => actionsDictionary[action];
  static createAction = (action, payload) => {
    const actionId = <%~ it.className %>.getAction(action);
    return { action: actionId, payload };
  };

