
# Epoch counter (module-level, shared across all instances)
_epoch = [1]


def get_epoch():
    return _epoch[0]


# Helpers
def get_state(name):
    return states_dictionary.get(name)


def get_action(name):
    return actions_dictionary.get(name)


def create_action(name, payload):
    return {'action': actions_dictionary.get(name), 'payload': payload}


def has_state(instance, state_name):
    return instance['state']() == states_dictionary.get(state_name)


