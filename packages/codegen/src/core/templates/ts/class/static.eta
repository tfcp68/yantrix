  static getState = (state: keyof typeof statesMap): TStateId => statesDictionary[state]!;
  static hasState = (instance: <%~ it.className %>, state: keyof typeof <%~ it.className %>.states) => instance.state === <%~ it.className %>.getState(state);
  static getAction = (action: keyof typeof actionsMap): TActionId => actionsDictionary[action]!;
  static createAction = (action: keyof typeof actionsMap, payload: TAutomataPayload) => {
    const actionId = <%~ it.className %>.getAction(action);
    return { action: actionId, payload };
  };
